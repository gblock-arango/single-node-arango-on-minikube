# This script installs:
# - Docker
# - kubectl
# - helm
# - minikube
#
# Run it on Ubuntu 22. See below for details on each step.
#
# kubectl:
# - https://kubernetes.io/docs/tasks/tools/install-kubectl-linux/
# helm:
# - https://helm.sh/docs/intro/install/
# minikube:
# - https://minikube.sigs.k8s.io/docs/start/
# - https://minikube.sigs.k8s.io/docs/drivers/docker/

set -e

echo "Updating apt..."
sudo apt-get update
sudo apt-get install -y apt-transport-https ca-certificates curl gpg docker.io

echo "Configuring Docker..."
sudo systemctl enable --now docker
sudo usermod -aG docker "$USER"

echo "Installing kubectl..."
sudo mkdir -p /etc/apt/keyrings
curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.30/deb/Release.key \
  | sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg
echo 'deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.30/deb/ /' \
  | sudo tee /etc/apt/sources.list.d/kubernetes.list > /dev/null
sudo apt-get update
sudo apt-get install -y kubectl

echo "Installing Helm..."
curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

echo "Installing Minikube..."
curl -LO https://storage.googleapis.com/minikube/releases/latest/minikube_latest_amd64.deb
sudo dpkg -i minikube_latest_amd64.deb
rm -f minikube_latest_amd64.deb

echo "Setting default Kubernetes version for Minikube..."
minikube config set kubernetes-version v1.30.14

echo
echo "Installed versions:"
kubectl version --client
helm version
minikube version

echo
echo "IMPORTANT:"
echo "1. Log out and log back in so your user gets Docker group access."
echo "2. Then start Minikube with:"
echo "   minikube start --driver=docker (or minikube start --driver=docker --kubernetes-version=v1.30.14)"

